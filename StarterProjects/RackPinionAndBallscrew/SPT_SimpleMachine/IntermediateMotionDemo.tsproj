		<DataType>
			<Name GUID="{657520DB-518C-41A3-9E92-0670C7E6804F}" Namespace="VN">ETcVnPixelEncoding</Name>
			<Comment><![CDATA[Offers pixel encodings.]]></Comment>
			<BitSize>8</BitSize>
			<BaseType GUID="{18071995-0000-0000-0000-000000000001}">BYTE</BaseType>
			<EnumInfo>
				<Text><![CDATA[TCVN_PE_NONE]]></Text>
				<Enum>0</Enum>
				<Comment><![CDATA[No encoding available, i.e. every pixel value is independent of other pixels.]]></Comment>
			</EnumInfo>
			<EnumInfo>
				<Text><![CDATA[TCVN_PE_BAYER_GR]]></Text>
				<Enum>1</Enum>
				<Comment><![CDATA[Pixels are encoded as a BayerGR pattern.]]></Comment>
			</EnumInfo>
			<EnumInfo>
				<Text><![CDATA[TCVN_PE_BAYER_RG]]></Text>
				<Enum>2</Enum>
				<Comment><![CDATA[Pixels are encoded as a BayerRG pattern.]]></Comment>
			</EnumInfo>
			<EnumInfo>
				<Text><![CDATA[TCVN_PE_BAYER_GB]]></Text>
				<Enum>3</Enum>
				<Comment><![CDATA[Pixels are encoded as a BayerGB pattern.]]></Comment>
			</EnumInfo>
			<EnumInfo>
				<Text><![CDATA[TCVN_PE_BAYER_BG]]></Text>
				<Enum>4</Enum>
				<Comment><![CDATA[Pixels are encoded as a BayerBG pattern.]]></Comment>
			</EnumInfo>
			<EnumInfo>
				<Text><![CDATA[TCVN_PE_YUV_411_UYYVYY]]></Text>
				<Enum>5</Enum>
				<Comment><![CDATA[Pixels are encoded as YUV411 (UYYVYY).]]></Comment>
			</EnumInfo>
			<EnumInfo>
				<Text><![CDATA[TCVN_PE_YUV_422_UYVY]]></Text>
				<Enum>6</Enum>
				<Comment><![CDATA[Pixels are encoded as YUV422 (UYVY).]]></Comment>
			</EnumInfo>
			<EnumInfo>
				<Text><![CDATA[TCVN_PE_YUV_422_YUYV]]></Text>
				<Enum>7</Enum>
				<Comment><![CDATA[Pixels are encoded as YUV422 (YUYV).]]></Comment>
			</EnumInfo>
			<EnumInfo>
				<Text><![CDATA[TCVN_PE_YCBCR_411_CBYYCRYY]]></Text>
				<Enum>8</Enum>
				<Comment><![CDATA[Pixels are encoded as YCbCr411 (CbYYCrYY).]]></Comment>
			</EnumInfo>
			<EnumInfo>
				<Text><![CDATA[TCVN_PE_YCBCR_422_CBYCRY]]></Text>
				<Enum>9</Enum>
				<Comment><![CDATA[Pixels are encoded as YCbCr422 (CbYCrY).]]></Comment>
			</EnumInfo>
			<EnumInfo>
				<Text><![CDATA[TCVN_PE_YCBCR_422_YCBYCR]]></Text>
				<Enum>10</Enum>
				<Comment><![CDATA[Pixels are encoded as YCbCr422 (YCbYCr).]]></Comment>
			</EnumInfo>
			<Hides>
				<Hide GUID="{BF936234-C5D0-4D32-8DC1-AF97BCB6440A}"/>
				<Hide GUID="{DAADE67D-855E-4435-BC14-F8967FFE4DF9}"/>
				<Hide GUID="{400FEB06-2DFF-481A-9EE8-28C6B2B03B01}"/>
				<Hide GUID="{74F529B8-70EC-4535-8DD0-2D164AA7A350}"/>
