		<DataType>
			<Name GUID="{C10B6EE2-EA6E-4FED-AC4E-D3C8366F26C0}">ITcVnData</Name>
			<Comment><![CDATA[Interface for accessing data.]]></Comment>
			<BitSize X64="64">32</BitSize>
			<BaseType GUID="{00000001-0000-0000-E000-000000000064}">ITcUnknown</BaseType>
			<Method>
				<Name>CheckIfCopy</Name>
				<Comment><![CDATA[Check if the data are a copy (returns S_OK for copies and S_FALSE otherwise).]]></Comment>
				<ReturnType GUID="{18071995-0000-0000-0000-000000000019}">HRESULT</ReturnType>
				<ReturnBitSize>32</ReturnBitSize>
			</Method>
			<Method>
				<Name>CheckIfImage</Name>
				<Comment><![CDATA[Check if the data belongs to an image (returns S_OK for images and S_FALSE otherwise).]]></Comment>
				<ReturnType GUID="{18071995-0000-0000-0000-000000000019}">HRESULT</ReturnType>
				<ReturnBitSize>32</ReturnBitSize>
			</Method>
			<Method>
				<Name>GetSize</Name>
				<Comment><![CDATA[Gets the size of the data.]]></Comment>
				<ReturnType GUID="{18071995-0000-0000-0000-000000000019}">HRESULT</ReturnType>
				<ReturnBitSize>32</ReturnBitSize>
				<Parameter>
					<Name>nSize</Name>
					<Comment><![CDATA[Size of the stored data in bytes.]]></Comment>
					<Type GUID="{18071995-0000-0000-0000-00000000000B}" ReferenceTo="true">ULINT</Type>
					<BitSize X64="64">32</BitSize>
				</Parameter>
			</Method>
			<Method>
				<Name>CheckDataPointer</Name>
				<Comment><![CDATA[Check if the data pointer is different from 0 (returns S_OK for non-zero data pointers and S_FALSE otherwise).]]></Comment>
				<ReturnType GUID="{18071995-0000-0000-0000-000000000019}">HRESULT</ReturnType>
				<ReturnBitSize>32</ReturnBitSize>
			</Method>
			<Method>
				<Name>GetDataPointer</Name>
				<Comment><![CDATA[Gets the data pointer (the obtained data pointer must be released by calling ReleaseDataPointer).]]></Comment>
				<ReturnType GUID="{18071995-0000-0000-0000-000000000019}">HRESULT</ReturnType>
				<ReturnBitSize>32</ReturnBitSize>
				<Parameter>
					<Name>ppData</Name>
					<Comment><![CDATA[Returns the data pointer.]]></Comment>
					<Type GUID="{18071995-0000-0000-0000-000000000018}" PointerTo="1">PVOID</Type>
					<BitSize X64="64">32</BitSize>
				</Parameter>
			</Method>
			<Method>
				<Name>ReleaseDataPointer</Name>
				<Comment><![CDATA[Release the data pointer.]]></Comment>
				<ReturnType GUID="{18071995-0000-0000-0000-000000000019}">HRESULT</ReturnType>
				<ReturnBitSize>32</ReturnBitSize>
				<Parameter>
					<Name>ppData</Name>
					<Comment><![CDATA[Pointer to the data pointer to be released.]]></Comment>
					<Type GUID="{18071995-0000-0000-0000-000000000018}" PointerTo="1">PVOID</Type>
					<BitSize X64="64">32</BitSize>
				</Parameter>
			</Method>
