				<Comment><![CDATA[RGB565p]]></Comment>
			</EnumInfo>
			<EnumInfo>
				<Text><![CDATA[TCVN_PPM_BGR565P]]></Text>
				<Enum>10</Enum>
				<Comment><![CDATA[BGR565p]]></Comment>
			</EnumInfo>
			<EnumInfo>
				<Text><![CDATA[TCVN_PPM_MONO10P]]></Text>
				<Enum>11</Enum>
				<Comment><![CDATA[Mono10p or BayerXX10p]]></Comment>
			</EnumInfo>
			<EnumInfo>
				<Text><![CDATA[TCVN_PPM_MONO12P]]></Text>
				<Enum>12</Enum>
				<Comment><![CDATA[Mono12p or BayerXX12p]]></Comment>
