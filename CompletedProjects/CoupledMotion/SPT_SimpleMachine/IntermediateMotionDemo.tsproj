		<DataType>
			<Name GUID="{1757E396-5DF0-4407-B0EB-1037B2E8B4EE}" Namespace="VN">TcVnPixelFormat</Name>
			<Comment><![CDATA[Contains detailed information about the pixel format.]]></Comment>
			<BitSize>64</BitSize>
			<SubItem>
				<Name>bSupported</Name>
				<Type GUID="{18071995-0000-0000-0000-000000000010}">BIT</Type>
				<Comment><![CDATA[If false, the pixel format is not supported.]]></Comment>
				<BitSize>1</BitSize>
				<BitOffs>0</BitOffs>
			</SubItem>
			<SubItem>
				<Name>bSigned</Name>
				<Type GUID="{18071995-0000-0000-0000-000000000010}">BIT</Type>
				<Comment><![CDATA[If true, pixel intensities are signed values.]]></Comment>
				<BitSize>1</BitSize>
				<BitOffs>1</BitOffs>
			</SubItem>
			<SubItem>
				<Name>bPlanar</Name>
				<Type GUID="{18071995-0000-0000-0000-000000000010}">BIT</Type>
				<Comment><![CDATA[If true, the image channels are stored planar instead of interleaved (e.g. RRRRRGGGGGBBBBB instead of RGBRGBRGBRGBRGB).]]></Comment>
				<BitSize>1</BitSize>
				<BitOffs>2</BitOffs>
			</SubItem>
			<SubItem>
				<Name>bFloat</Name>
				<Type GUID="{18071995-0000-0000-0000-000000000010}">BIT</Type>
				<Comment><![CDATA[If true, the pixel format is floating point.]]></Comment>
				<BitSize>1</BitSize>
				<BitOffs>4</BitOffs>
			</SubItem>
			<SubItem>
				<Name>nChannels</Name>
				<Type GUID="{18071995-0000-0000-0000-000000000001}">BYTE</Type>
				<Comment><![CDATA[Number of channels]]></Comment>
				<BitSize>8</BitSize>
				<BitOffs>8</BitOffs>
			</SubItem>
			<SubItem>
				<Name>ePixelEncoding</Name>
				<Type GUID="{657520DB-518C-41A3-9E92-0670C7E6804F}" Namespace="VN">ETcVnPixelEncoding</Type>
				<Comment><![CDATA[Pixel encoding]]></Comment>
