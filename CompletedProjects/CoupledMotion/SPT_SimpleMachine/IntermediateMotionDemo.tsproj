				<ReturnBitSize>32</ReturnBitSize>
			</Method>
			<Method>
				<Name>CheckIfImage</Name>
				<Comment><![CDATA[Check if the data belongs to an image (returns S_OK for images and S_FALSE otherwise).]]></Comment>
